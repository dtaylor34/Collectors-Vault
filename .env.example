# ═══════════════════════════════════════════════════════════════
# The Collector's Vault — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# Supabase (create at supabase.com)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Firebase (reusing radstash-61837 project)
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=radstash-61837.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=radstash-61837
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=radstash-61837.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id

# Anthropic (for Claude Vision AI — server-side only, NOT in client)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Stripe (for marketplace payments)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key

# PostHog (analytics — optional)
EXPO_PUBLIC_POSTHOG_KEY=phc_your-key
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
